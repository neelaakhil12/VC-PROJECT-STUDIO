{
  "rewrites": [
    {
      "source": "/api/send-reset-email",
      "destination": "/api/send-reset-email.cjs"
    },
    {
      "source": "/api/keep-alive",
      "destination": "/api/keep-alive.cjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 0 * * *"
    }
  ]
}
